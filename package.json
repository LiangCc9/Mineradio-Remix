{
  "name": "mineradio-remix",
  "productName": "Mineradio Remix",
  "version": "1.1.1",
  "description": "基于 Mineradio 的非官方个人二创版：网易云音乐、粒子封面、电影歌词与克制的情绪视觉。",
  "author": "LiangCc9",
  "license": "GPL-3.0-only",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win nsis",
    "build:win:dir": "electron-builder --win dir"
  },
  "build": {
    "appId": "com.liangcc9.mineradio.remix",
    "productName": "Mineradio Remix",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "!public/fonts/MiSans-Regular.woff2",
      "wallpaper-engine/**/*",
      "!wallpaper-engine/**/app/fonts/MiSans-Regular.woff2",
      "build/**/*",
      "server.js",
      "dj-analyzer.js",
      "package.json",
      "!public/index.*.html",
      "public/index.html"
    ],
    "asar": false,
    "win": {
      "executableName": "MineradioRemix",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mineradio Remix",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "artifactName": "Mineradio-Remix-${version}-Setup.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "LiangCc9",
        "repo": "Mineradio-Remix"
      }
    ]
  },
  "mineradio": {
    "update": {
      "provider": "github",
      "owner": "LiangCc9",
      "repo": "Mineradio-Remix",
      "preview": true,
      "preferMirrors": true,
      "mirrors": [
        "https://gh.llkk.cc/",
        "https://ghfast.top/",
        "https://gh-proxy.com/"
      ]
    }
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "NeteaseCloudMusicApi": "^4.32.0"
  },
  "overrides": {
    "music-metadata": "11.13.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "rcedit": "^5.0.2"
  }
}
